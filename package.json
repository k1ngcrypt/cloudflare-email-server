{
  "name": "cloudflare-webmail",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:create": "wrangler d1 create webmail-db",
    "db:migrate": "wrangler d1 execute webmail-db --file=./schema.sql"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "@noble/hashes": "^2.0.1",
    "hono": "^4.12.10",
    "mimetext": "^3.0.23",
    "postal-mime": "^2.4.4",
    "worker-mailer": "^1.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.14.1",
    "@cloudflare/workers-types": "^4.20260307.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.2",
    "wrangler": "^3.114.10"
  }
}
