{
  "name": "cloudflare-webmail",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:create": "wrangler d1 create webmail-db",
    "db:migrate": "wrangler d1 execute webmail-db --file=./schema.sql"
  },
  "dependencies": {
    "mimetext": "^3.0.23",
    "postal-mime": "^2.4.4",
    "worker-mailer": "^1.2.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260307.0",
    "typescript": "^5.8.3",
    "wrangler": "^3.114.10"
  }
}
